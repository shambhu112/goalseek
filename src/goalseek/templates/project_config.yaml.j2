provider:
  hypothesis:
    name: {{ provider_name }}
    model: {{ model_name }}
    non_interactive: true
    timeout_sec: 300
  implementation:
    name: {{ provider_name }}
    model: {{ model_name }}
    non_interactive: true
    timeout_sec: 300

loop:
  repair_attempts: 1
  stagnation_window: 3

output:
  rich: true

logging:
  enabled: true
  level: DEBUG
  format: "%(asctime)s %(levelname)s [%(name)s] %(message)s"
  handlers:
    - type: stdout
    - type: file
      path: logs/goalseek.log
    # - type: cloudwatch
    #   log_group: /goalseek/{{ project_name }}
    #   stream_name: "{project_name}"
